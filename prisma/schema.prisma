generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum FeedbackType {
  LIKE
  DISLIKE
}

model Winery {
  id       Int    @id @default(autoincrement())
  name     String @unique
  slug     String @unique
  lat      Float
  lng      Float
  category String

  wines Wine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Wine {
  id             Int    @id @default(autoincrement())
  name           String
  slug           String @unique
  color          String
  alcoholPercent Float
  vintage        Int
  bodyScore      Int
  aromaTags      String
  priceRangeMin  Float
  priceRangeMax  Float

  dolcezza      Float @default(0)
  acidita       Float @default(0)
  tannini       Float @default(0)
  corpo         Float @default(0)
  alcol         Float @default(0)
  effervescenza Float @default(0)
  fruttato      Float @default(0)
  floreale      Float @default(0)
  speziato      Float @default(0)
  terroso       Float @default(0)
  legnoso       Float @default(0)
  minerale      Float @default(0)

  wineryId Int
  winery   Winery @relation(fields: [wineryId], references: [id], onDelete: Cascade)

  wineAdditives  WineAdditive[]
  feedbackEvents WineFeedbackEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Additive {
  id          Int    @id @default(autoincrement())
  name        String @unique
  description String

  wineAdditives WineAdditive[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WineAdditive {
  wineId     Int
  additiveId Int

  wine     Wine     @relation(fields: [wineId], references: [id], onDelete: Cascade)
  additive Additive @relation(fields: [additiveId], references: [id], onDelete: Cascade)

  @@id([wineId, additiveId])
}

model SurveySession {
  id             String              @id @default(uuid())
  answers        SurveyAnswer[]
  profile        UserTasteProfile?
  feedbackEvents WineFeedbackEvent[]
  createdAt      DateTime            @default(now())
}

model SurveyAnswer {
  id              Int    @id @default(autoincrement())
  surveySessionId String
  questionId      String
  optionId        String

  surveySession SurveySession @relation(fields: [surveySessionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model UserTasteProfile {
  id              Int    @id @default(autoincrement())
  surveySessionId String @unique
  learningRate    Float  @default(0.25)

  baselineDolcezza      Float
  baselineAcidita       Float
  baselineTannini       Float
  baselineCorpo         Float
  baselineAlcol         Float
  baselineEffervescenza Float
  baselineFruttato      Float
  baselineFloreale      Float
  baselineSpeziato      Float
  baselineTerroso       Float
  baselineLegnoso       Float
  baselineMinerale      Float

  currentDolcezza      Float
  currentAcidita       Float
  currentTannini       Float
  currentCorpo         Float
  currentAlcol         Float
  currentEffervescenza Float
  currentFruttato      Float
  currentFloreale      Float
  currentSpeziato      Float
  currentTerroso       Float
  currentLegnoso       Float
  currentMinerale      Float

  surveySession SurveySession @relation(fields: [surveySessionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WineFeedbackEvent {
  id              Int          @id @default(autoincrement())
  surveySessionId String
  wineId          Int
  feedback        FeedbackType
  createdAt       DateTime     @default(now())

  surveySession SurveySession @relation(fields: [surveySessionId], references: [id], onDelete: Cascade)
  wine          Wine          @relation(fields: [wineId], references: [id], onDelete: Cascade)

  @@index([surveySessionId, createdAt])
}
